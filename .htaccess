<IfModule mod_rewrite.c>
RewriteEngine On

# Sitemap
RewriteRule ^sitemap\.xml$ sitemap.php [L]

# Si el archivo no existe (!-f) y el directorio no existe (!-d)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
# Redirigir a la carpeta principal (inicio)
RewriteRule ^(.*)$ /moratalla/ [R=301,L]
</IfModule>
