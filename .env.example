# =============================================
# Archivo de ejemplo de configuración de entorno
# =============================================
# Copia este archivo como .env en el servidor de producción
# y rellena con los valores reales de tu hosting Ionos.
#
# NUNCA subas el archivo .env real a GitHub.
# =============================================

APP_ENV=production

# Base de datos MySQL (datos de Ionos)
DB_HOST=db1234567890.hosting-data.io
DB_PORT=3306
DB_USER=dbu123456
DB_PASS=tu_contraseña_mysql_aqui
DB_NAME=dbs123456

# URL base (vacío si la web está en la raíz del dominio)
BASE_URL=

# Token secreto para ejecutar migraciones por HTTP
# Genera uno seguro: https://randomkeygen.com/
MIGRATE_SECRET=cambia-esto-por-un-token-aleatorio-seguro
